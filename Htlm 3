</style>

<script>
    const URL_JSON = "https://raw.githubusercontent.com/alfonsocamacho00089-cloud/captura_bcv.py/main/bancos.json";
    
    // Aquí pon los nombres de las imágenes exactos que subiste a GitHub
    const BASE_URL_LOGOS = "https://raw.githubusercontent.com/alfonsocamacho00089-cloud/captura_bcv.py/main/";

    function abrirTasas() {
        document.getElementById('modalBancos').style.display = 'flex';
        actualizarLista();
    }

    function cerrarTasas() {
        document.getElementById('modalBancos').style.display = 'none';
    }

    async function actualizarLista() {
        try {
            const res = await fetch(URL_JSON);
            const datos = await res.json();
            const contenedor = document.getElementById('listaContenedor');
            contenedor.innerHTML = '';

            datos.forEach(b => {
                let nombreLimpio = b.banco.replace(/\\u00e9/g, 'é').replace(/\\u00ed/g, 'í').replace(/\\u00f3/g, 'ó');
                
                // Intentamos armar el nombre del logo (ej: "Banesco" -> "banesco.png")
                let nombreLogo = nombreLimpio.toLowerCase().split(' ')[0] + ".png"; 

                contenedor.innerHTML += `
                    <div class="card-banco">
                        <img src="${BASE_URL_LOGOS}${nombreLogo}" onerror="this.src='https://cdn-icons-png.flaticon.com/512/2830/2830284.png'" class="img-logo">
                        <div style="flex:1">
                            <div style="font-size:12px; color:#888;">Banco</div>
                            <div style="font-weight:bold; color:#333;">${nombreLimpio}</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:12px; color:#888;">Precio</div>
                            <div style="font-size:20px; font-weight:bold; color:#008080;">${parseFloat(b.precio).toFixed(2)}</div>
                        </div>
                    </div>
                `;
            });
        } catch (e) {
            console.error(e);
        }
    }
</script>


