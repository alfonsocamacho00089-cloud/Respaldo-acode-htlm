function actualizar() {
    const d = new Date();
    const dia = d.getDay(); 
    const hora = d.getHours();
    
    // --- LÓGICA DE TIEMPO (FIJA) ---
    // Detecta si es fin de semana (Viernes 4pm hasta Domingo 11:59pm)
    const isFinDeSemana = (dia === 5 && hora >= 16) || dia === 6 || dia === 0;
    
    // Detecta qué tasa eligió el usuario en el Switch (Hoy o Mañana)
    const isMañana = document.getElementById("nextDaySwitch").checked;

    // --- CAPTURA DE DATOS (CON RESPALDO) ---
    const pUSD = parseFloat(document.getElementById("priceUSD").value) || 0;
    const pCli = parseFloat(document.getElementById("priceCli").value) || 0;
    
    // Si tApi.p2p es 0 (falló la API), busca en la memoria (localStorage)
const p2pReal = tApi.p2p || parseFloat(localStorage.getItem("res_p2p_hoy"));
    // --- SELECCIÓN DINÁMICA DE TASA ---
    let tBase = 0;
    let nombreTasa = (tasaSeleccionada === 'bcv') ? "BCV" : "EURO";

    if (tasaSeleccionada === 'bcv') {
        tBase = isMañana ? tMan.bcv : tApi.bcv;
        // Si las variables están en 0 (API caída), usa el respaldo guardado
        if (tBase === 0) {
            tBase = isMañana ? parseFloat(localStorage.getItem("res_bcv_prox")) : parseFloat(localStorage.getItem("res_bcv_hoy"));
        }
    } else {
        tBase = isMañana ? tMan.euro : tApi.euro;
        if (tBase === 0) {
            tBase = isMañana ? parseFloat(localStorage.getItem("res_euro_prox")) : parseFloat(localStorage.getItem("res_euro_hoy"));
        }
    }
if (!tBase || isNaN(tBase)) tBase = 0;
    // --- MOTOR DE CÁLCULO (IGTF 3%) ---
    const procesar = (monto) => {
        const baseBS = monto * tBase;
        const igtfBS = baseBS * 0.03;
        const totalBS = baseBS + igtfBS;
        const totalUSDT = (p2pReal > 0) ? (totalBS / p2pReal) : 0;
        return { baseBS, igtfBS, totalBS, totalUSDT };
    };
// --- ACTUALIZACIÓN DE PANTALLAS (COMERCIO Y CLIENTE) ---
    const resCom = procesar(pUSD);
    document.getElementById("labelVES").textContent = `${nombreTasa} ${format(resCom.baseBS)} + IGTF ${format(resCom.igtfBS)}`;
    document.getElementById("totalVES").value = format(resCom.totalBS) + " Bs";
    document.getElementById("totalUSDT").value = resCom.totalUSDT.toFixed(2);
    const resCli = procesar(pCli);
    document.getElementById("labelCli").textContent = `${nombreTasa} ${format(resCli.baseBS)} + IGTF ${format(resCli.igtfBS)}`;
    document.getElementById("bsCliBCV").value = format(resCli.totalBS) + " Bs";
    document.getElementById("usdtCliFinal").value = resCli.totalUSDT.toFixed(2);
    // --- ACTUALIZACIÓN DE INTERFAZ EXCHANGE ---
    document.getElementById("p2pRate").value = p2pReal.toFixed(2);
    document.getElementById("labBuy").textContent = p2pReal.toFixed(2);
    document.getElementById("labSell").textContent = p2pReal.toFixed(2);
    
    const uBuyVal = parseFloat(document.getElementById("uBuy").value) || 0;
    document.getElementById("resBuy").value = format(uBuyVal * p2pReal) + " Bs";
    const uSellVal = parseFloat(document.getElementById("uSell").value) || 0;
   document.getElementById("resSell").value = format(uSellVal * p2pReal) + " Bs";
    // Actualiza los valores de "atrás" de las tarjetas (Flip)
   if (document.getElementById("bcvRateBack")){
    document.getElementById("bcvRateBack").value = tMan.bcv.toFixed(2);
   }
  if (document.getElementById("euroRateBack")){
    document.getElementById("euroRateBack").value = tMan.euro.toFixed(2);
}
}
