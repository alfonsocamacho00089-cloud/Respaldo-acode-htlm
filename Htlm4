            tMan.bcv = parseFloat(dataV[0].precio_dolar) || 0;
            tMan.euro = parseFloat(dataV[0].precio_euro) || 0;

            const nuevoBCV = tApi.bcv;
            const anteriorBCV = parseFloat(localStorage.getItem("res_bcv_hoy")) || 0;

            if (nuevoBCV !== anteriorBCV && nuevoBCV > 0) {
                const ahoraStr = new Date().toLocaleTimeString('es-VE', {
                    hour: '2-digit', minute: '2-digit', hour12: true
                });
                localStorage.setItem("horaBCV", ahoraStr);
                if(document.getElementById("timeDisplay")) {
                    document.getElementById("timeDisplay").textContent = `ÚLTIMA ACTUALIZACIÓN BCV: ${ahoraStr}`;
                }
            }
            
            // Guardar en caché
            if (tMan.bcv > 0) localStorage.setItem("res_bcv", tMan.bcv);
            if (tMan.euro > 0) localStorage.setItem("res_euro", tMan.euro);
            if (tApi.bcv > 0) localStorage.setItem("res_bcv_hoy", tApi.bcv);
            if (tApi.euro > 0) localStorage.setItem("res_euro_hoy", tApi.euro);
        } else {
            throw new Error("Datos incompletos");
        }
    } catch (error) {
        console.warn("Fallo BCV, usando LocalStorage");
        tMan.bcv = parseFloat(localStorage.getItem("res_bcv")) || 0;
        tMan.euro = parseFloat(localStorage.getItem("res_euro")) || 0;
        tApi.bcv = parseFloat(localStorage.getItem("res_bcv_hoy")) || 0;
        tApi.euro = parseFloat(localStorage.getItem("res_euro_hoy")) || 0;
    }

    // --- BLOQUE 2: P2P (BINANCE/DOLARAPI) ---
    try {
        const resB = await fetch(urlP2P);
        const dataB = await resB.json();
        if (dataB && dataB.binance) {
            const nuevoP2P = parseFloat(dataB.binance.price) || 0;
            const anteriorP2P = parseFloat(localStorage.getItem("res_p2p_hoy")) || 0;

            if (nuevoP2P !== anteriorP2P) {
                const horaP2P = new Date().toLocaleTimeString('es-VE', {
                    hour: '2-digit', minute: '2-digit', hour12: true
                });
                localStorage.setItem("horaP2P", horaP2P);
                if (document.getElementById("timeP2PDisplay")) {
                    document.getElementById("timeP2PDisplay").textContent = "ACTUALIZADO P2P: " + horaP2P;
                }
            }
            tApi.p2p = nuevoP2P;
            localStorage.setItem("res_p2p_hoy", nuevoP2P);
        } else {
            throw new Error("GitHub P2P Vacío");
        }
    } catch (error) {
        console.warn("Fallo GitHub P2P, intentando DolarApi...");
        try {
            const resRespaldo = await fetch("https://ve.dolarapi.com/v1/dolares/paralelo");
            const dataR = await resRespaldo.json();
            tApi.p2p = parseFloat(dataR.promedio) || 0;
            localStorage.setItem("res_p2p_hoy", tApi.p2p);
        } catch (errorApi) {
            console.error("Fallo total P2P");
            tApi.p2p = parseFloat(localStorage.getItem("res_p2p_hoy")) || 0;
        }
    }

    // --- FINALIZACIÓN Y UI ---
    try {
        if(document.getElementById('bcvRate')) document.getElementById('bcvRate').value = tApi.bcv.toFixed(2);
        if(document.getElementById('p2pRate')) document.getElementById('p2pRate').value = tApi.p2p.toFixed(2);
        if(document.getElementById('euroRate')) document.getElementById('euroRate').value = tApi.euro.toFixed(2);
        if(document.getElementById('bcvRateBack')) document.getElementById('bcvRateBack').value = tMan.bcv.toFixed(2);
        if(document.getElementById('euroRateBack')) document.getElementById('euroRateBack').value = tMan.euro.toFixed(2);

        actualizar();
        if (typeof cargarShopping === 'function') cargarShopping();
    } catch (e) {
        console.error("Error UI:", e);
    } finally {
        setTimeout(() => {
            if (icono) icono.classList.remove("girando");
        }, 600);
    }
