function updateDate() {
    const d = new Date();
    const hora = d.getHours();
    const diaSemana = d.getDay(); 
    let fechaDestino = new Date(d);
   
    // LÓGICA DE FECHAS:
    if ((diaSemana === 5 && hora >= 16) || diaSemana === 6 || diaSemana === 0) {
        // Si es Viernes tarde (3 días), Sábado (2 días) o Domingo (1 día) para llegar al lunes
        let diasParaLunes = (diaSemana === 5) ? 3 : (diaSemana === 6 ? 2 : 1);
        fechaDestino.setDate(d.getDate() + diasParaLunes);
    } else {
        fechaDestino.setDate(d.getDate() + 1); 
    }

    // Formateo de strings
    const fProxima = `${fechaDestino.getDate().toString().padStart(2, '0')}/${(fechaDestino.getMonth() + 1).toString().padStart(2, '0')}/${fechaDestino.getFullYear()}`;
    const fHoy = `${d.getDate().toString().padStart(2, '0')}/${(d.getMonth() + 1).toString().padStart(2, '0')}/${d.getFullYear()}`;
    
    // --- ASIGNACIÓN A PANTALLA CON PROTECCIÓN ---
    const elHoy = document.getElementById("dateDisplay");
    const elProx = document.getElementById("dateNextDisplay"); // <--- REVISA ESTE ID EN TU HTML

    if (elHoy) elHoy.textContent = fHoy;
    if (elProx) elProx.textContent = fProxima;

    // --- ACTUALIZACIÓN DE HORA (BCV ESTÁTICO / P2P DINÁMICO) ---
    const hFija = localStorage.getItem("horaBCV");
    const displayElement = document.getElementById("timeDisplay");

    if (displayElement) {
        displayElement.textContent = hFija ? `ÚLTIMA ACTUALIZACIÓN BCV: ${hFija}` : `ÚLTIMA ACTUALIZACIÓN BCV: No disponible`;
    }
}

